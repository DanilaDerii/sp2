@startuml
title SP2 Local-First System Architecture

skinparam backgroundColor white
skinparam packageStyle rectangle
skinparam shadowing false
skinparam ArrowColor #444444
skinparam DefaultFontName Arial
skinparam componentStyle rectangle

actor Professor
actor Student

rectangle "SP2 App" as SP2 {

  package "Teacher Side" as Teacher {
    [Teacher UI]

    package "RAG Build Pipeline" as BuildPipeline {
      [Docling Worker]
      [Chunker]
      [Embedder]
      [Pack Writer]
      [ZIP Exporter]
      [Pipeline Orchestrator]
    }
  }

  package "Student Side" as StudentSide {
    [Student UI]
    [Pack Import API]
    [Retrieval Service]
    [Chat Service]
  }

  package "Shared Local Storage" as Storage {
    database "SQLite\napp.db" as SQLite
    database "LanceDB\ncourse_chunks" as LanceDB
    folder "Installed Packs\npack.json / chunks.json / vectors.npy" as InstalledPacks
    folder "Temp / Export Data" as TempData
  }

  package "Local AI Runtime" as LocalAI {
    [Ollama]
    [Embedding Model\nall-minilm:latest]
    [Generation Model\nqwen2.5:3b]
  }
}

cloud "Teams / LMS / Drive\npack distribution only" as Distribution

folder "Course Materials\nPDF / PPT / Audio" as CourseMaterials
file "Portable Course Pack\n.zip" as PackZip

Professor --> [Teacher UI]
[Teacher UI] --> [Pipeline Orchestrator]
[Pipeline Orchestrator] --> [Docling Worker]
[Pipeline Orchestrator] --> [Chunker]
[Pipeline Orchestrator] --> [Embedder]
[Pipeline Orchestrator] --> [Pack Writer]
[Pipeline Orchestrator] --> [ZIP Exporter]

[Docling Worker] --> CourseMaterials
[Chunker] --> [Docling Worker]
[Embedder] --> [Chunker]
[Embedder] --> [Ollama]
[Ollama] --> [Embedding Model\nall-minilm:latest]
[Pack Writer] --> TempData
[ZIP Exporter] --> PackZip
PackZip --> Distribution

Student --> [Student UI]
[Student UI] --> [Pack Import API]
Distribution --> PackZip
PackZip --> [Pack Import API]
[Pack Import API] --> InstalledPacks
[Pack Import API] --> SQLite
[Pack Import API] --> LanceDB

[Student UI] --> [Chat Service]
[Chat Service] --> [Retrieval Service]
[Retrieval Service] --> [Ollama]
[Ollama] --> [Embedding Model\nall-minilm:latest]
[Retrieval Service] --> LanceDB
[Chat Service] --> [Ollama]
[Ollama] --> [Generation Model\nqwen2.5:3b]
[Chat Service] --> SQLite
[Chat Service] --> [Student UI]

note right of Distribution
Core usage stays local.
Cloud is optional later for:
- pack distribution
- storage/versioning
- feedback workflows
end note

note bottom of Storage
Pack format:
- pack.json
- chunks.json
- vectors.npy

Runtime split:
- SQLite = app state / chat history
- LanceDB = retrieval index
end note

@enduml
